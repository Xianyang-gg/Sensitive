<template>
  <div class="app-container">
    <el-card class="box-card" style="margin-bottom: 16px">
      <template #header>
        <div class="clearfix">
          <span>${functionName}信息</span>
          <el-button style="float: right" link type="primary" icon="Back" @click="goBack">返回</el-button>
        </div>
      </template>
      <el-descriptions :column="2" border>
#foreach($column in $columns)
#if(!$column.pk && $column.list)
#set($dictType=$column.dictType)
#set($javaField=$column.javaField)
#set($parentheseIndex=$column.columnComment.indexOf("（"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
        <el-descriptions-item label="${comment}">
#if("" != $dictType)
#if($column.htmlType == "checkbox")
          <dict-tag :options="${dictType}" :value="master.${javaField} ? master.${javaField}.split(',') : []" />
#else
          <dict-tag :options="${dictType}" :value="master.${javaField}" />
#end
#elseif($column.htmlType == "datetime")
          {{ parseTime(master.${javaField}, '{y}-{m}-{d}') }}
#elseif($column.htmlType == "imageUpload")
          <image-preview :src="master.${javaField}" :width="60" :height="60" />
#else
          {{ master.${javaField} }}
#end
        </el-descriptions-item>
#end
#end
      </el-descriptions>
    </el-card>

    <el-card class="box-card">
      <template #header>
        <span>${subTable.functionName}信息</span>
      </template>
      <el-row :gutter="10" class="mb8">
        <el-col :span="1.5">
          <el-button type="primary" plain icon="Plus" @click="handleAddSub" v-hasPermi="['${permissionPrefix}:add']">新增</el-button>
        </el-col>
        <el-col :span="1.5">
          <el-button type="danger" plain icon="Delete" :disabled="multiple" @click="handleDeleteSub()" v-hasPermi="['${permissionPrefix}:remove']">删除</el-button>
        </el-col>
      </el-row>

      <el-table v-loading="subLoading" :data="${subclassName}List" @selection-change="handleSubSelectionChange">
        <el-table-column type="selection" width="55" align="center" />
#foreach($column in $subTable.columns)
#set($javaField=$column.javaField)
#set($parentheseIndex=$column.columnComment.indexOf("（"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
#if($column.pk || $javaField == ${subTableFkclassName})
#elseif($column.list && $column.htmlType == "datetime")
        <el-table-column label="${comment}" align="center" prop="${javaField}" width="180">
          <template #default="scope">
            <span>{{ parseTime(scope.row.${javaField}, '{y}-{m}-{d}') }}</span>
          </template>
        </el-table-column>
#elseif($column.list && $column.htmlType == "imageUpload")
        <el-table-column label="${comment}" align="center" prop="${javaField}" width="100">
          <template #default="scope">
            <image-preview :src="scope.row.${javaField}" :width="50" :height="50"/>
          </template>
        </el-table-column>
#elseif($column.list && "" != $column.dictType)
        <el-table-column label="${comment}" align="center" prop="${javaField}">
          <template #default="scope">
#if($column.htmlType == "checkbox")
            <dict-tag :options="${column.dictType}" :value="scope.row.${javaField} ? scope.row.${javaField}.split(',') : []"/>
#else
            <dict-tag :options="${column.dictType}" :value="scope.row.${javaField}"/>
#end
          </template>
        </el-table-column>
#elseif($column.list)
        <el-table-column label="${comment}" align="center" prop="${javaField}" />
#end
#end
        <el-table-column label="操作" align="center" class-name="small-padding fixed-width">
          <template #default="scope">
            <el-button link type="primary" icon="Edit" @click="handleUpdateSub(scope.row)" v-hasPermi="['${permissionPrefix}:edit']">修改</el-button>
            <el-button link type="primary" icon="Delete" @click="handleDeleteSub(scope.row)" v-hasPermi="['${permissionPrefix}:remove']">删除</el-button>
          </template>
        </el-table-column>
      </el-table>

      <pagination
        v-show="total>0"
        :total="total"
        v-model:page="queryParams.pageNum"
        v-model:limit="queryParams.pageSize"
        @pagination="getSubList"
      />
    </el-card>

    <!-- 添加或修改${subTable.functionName}对话框 -->
    <el-dialog :title="subTitle" v-model="subOpen" width="500px" append-to-body>
      <el-form ref="subFormRef" :model="subForm" :rules="subRules" label-width="100px">
#foreach($column in $subTable.columns)
#set($field=$column.javaField)
#if($column.insert && !$column.pk && $field != ${subTableFkclassName})
#if(($column.usableColumn) || (!$column.superColumn))
#set($parentheseIndex=$column.columnComment.indexOf("（"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
#set($dictType=$column.dictType)
#if($column.htmlType == "input")
        <el-form-item label="${comment}" prop="${field}">
          <el-input v-model="subForm.${field}" placeholder="请输入${comment}" />
        </el-form-item>
#elseif($column.htmlType == "imageUpload")
        <el-form-item label="${comment}" prop="${field}">
          <image-upload v-model="subForm.${field}"/>
        </el-form-item>
#elseif($column.htmlType == "fileUpload")
        <el-form-item label="${comment}" prop="${field}">
          <file-upload v-model="subForm.${field}"/>
        </el-form-item>
#elseif($column.htmlType == "editor")
        <el-form-item label="${comment}">
          <editor v-model="subForm.${field}" :min-height="192"/>
        </el-form-item>
#elseif($column.htmlType == "select" && "" != $dictType)
        <el-form-item label="${comment}" prop="${field}">
          <el-select v-model="subForm.${field}" placeholder="请选择${comment}">
            <el-option
              v-for="dict in ${dictType}"
              :key="dict.value"
              :label="dict.label"
#if($column.javaType == "Integer" || $column.javaType == "Long")
              :value="parseInt(dict.value)"
#else
              :value="dict.value"
#end
            ></el-option>
          </el-select>
        </el-form-item>
#elseif($column.htmlType == "select" && $dictType)
        <el-form-item label="${comment}" prop="${field}">
          <el-select v-model="subForm.${field}" placeholder="请选择${comment}">
            <el-option label="请选择字典生成" value="" />
          </el-select>
        </el-form-item>
#elseif($column.htmlType == "checkbox" && "" != $dictType)
        <el-form-item label="${comment}" prop="${field}">
          <el-checkbox-group v-model="subForm.${field}">
            <el-checkbox
              v-for="dict in ${dictType}"
              :key="dict.value"
              :label="dict.value">
              {{dict.label}}
            </el-checkbox>
          </el-checkbox-group>
        </el-form-item>
#elseif($column.htmlType == "checkbox" && $dictType)
        <el-form-item label="${comment}" prop="${field}">
          <el-checkbox-group v-model="subForm.${field}">
            <el-checkbox>请选择字典生成</el-checkbox>
          </el-checkbox-group>
        </el-form-item>
#elseif($column.htmlType == "radio" && "" != $dictType)
        <el-form-item label="${comment}" prop="${field}">
          <el-radio-group v-model="subForm.${field}">
            <el-radio
              v-for="dict in ${dictType}"
              :key="dict.value"
#if($column.javaType == "Integer" || $column.javaType == "Long")
              :label="parseInt(dict.value)"
#else
              :label="dict.value"
#end
            >{{dict.label}}</el-radio>
          </el-radio-group>
        </el-form-item>
#elseif($column.htmlType == "radio" && $dictType)
        <el-form-item label="${comment}" prop="${field}">
          <el-radio-group v-model="subForm.${field}">
            <el-radio label="1">请选择字典生成</el-radio>
          </el-radio-group>
        </el-form-item>
#elseif($column.htmlType == "datetime")
        <el-form-item label="${comment}" prop="${field}">
          <el-date-picker clearable
            v-model="subForm.${field}"
            type="date"
            value-format="YYYY-MM-DD"
            placeholder="请选择${comment}">
          </el-date-picker>
        </el-form-item>
#elseif($column.htmlType == "textarea")
        <el-form-item label="${comment}" prop="${field}">
          <el-input v-model="subForm.${field}" type="textarea" placeholder="请输入内容" />
        </el-form-item>
#end
#end
#end
#end
      </el-form>
      <template #footer>
        <div class="dialog-footer">
          <el-button type="primary" @click="submitSub">确 定</el-button>
          <el-button @click="subOpen = false">取 消</el-button>
        </div>
      </template>
    </el-dialog>
  </div>
</template>

<script setup lang="ts" name="${BusinessName}Detail">
import { useRoute, useRouter } from 'vue-router'
import type { ${ClassName}, ${subClassName} } from "@/types/api/${moduleName}/${businessName}"
import { get${BusinessName}, listSub${subClassName}, getSub${subClassName}, addSub${subClassName}, updateSub${subClassName}, delSub${subClassName} } from "@/api/${moduleName}/${businessName}"

const { proxy } = getCurrentInstance()
const route = useRoute()
const router = useRouter()
#if(${dicts} != '')
#set($dictsNoSymbol=$dicts.replace("'", ""))
const { ${dictsNoSymbol} } = useDict(${dicts})
#end

const ${pkColumn.javaField} = #if($pkColumn.javaType == "Long" || $pkColumn.javaType == "Integer")Number(route.query.${pkColumn.javaField})#{else}route.query.${pkColumn.javaField} as string#end

const master = ref<Partial<${ClassName}>>({})
const ${subclassName}List = ref<${subClassName}[]>([])
const total = ref<number>(0)
const subLoading = ref<boolean>(true)
const subOpen = ref<boolean>(false)
const subTitle = ref<string>("")
const subIds = ref<(number | string)[]>([])
const multiple = ref<boolean>(true)

const data = reactive({
  subForm: {} as Partial<${subClassName}>,
  queryParams: {
    pageNum: 1,
    pageSize: 10,
    ${subTableFkclassName}: ${pkColumn.javaField}
  } as any,
  subRules: {
#foreach ($column in $subTable.columns)
#if($column.required && !$column.pk && $column.javaField != ${subTableFkclassName})
#set($parentheseIndex=$column.columnComment.indexOf("（"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
    $column.javaField: [
      { required: true, message: "$comment不能为空", trigger: #if($column.htmlType == "select" || $column.htmlType == "radio")"change"#else"blur"#end }
    ],
#end
#end
  }
})

const { queryParams, subForm, subRules } = toRefs(data)

/** 查询${functionName}主表信息 */
function getMaster(): void {
  get${BusinessName}(${pkColumn.javaField}).then(response => {
    master.value = response.data || {}
  })
}

/** 查询${subTable.functionName}列表 */
function getSubList(): void {
  subLoading.value = true
  listSub${subClassName}(queryParams.value).then(response => {
    ${subclassName}List.value = response.rows
    total.value = response.total
    subLoading.value = false
  })
}

/** 子表多选框选中数据 */
function handleSubSelectionChange(selection: ${subClassName}[]): void {
  subIds.value = selection.map(item => item.${subTable.pkColumn.javaField}!)
  multiple.value = !selection.length
}

/** 子表表单重置 */
function resetSub(): void {
  subForm.value = {
#foreach ($column in $subTable.columns)
#if($column.htmlType == "checkbox")
    $column.javaField: [],
#else
    $column.javaField: undefined,
#end
#end
  }
  proxy.resetForm("subFormRef")
}

/** 子表新增按钮操作 */
function handleAddSub(): void {
  resetSub()
  subForm.value.${subTableFkclassName} = ${pkColumn.javaField} as any
  subOpen.value = true
  subTitle.value = "添加${subTable.functionName}"
}

/** 子表修改按钮操作 */
function handleUpdateSub(row: ${subClassName}): void {
  resetSub()
  getSub${subClassName}(row.${subTable.pkColumn.javaField} as number).then(response => {
    subForm.value = response.data
#foreach ($column in $subTable.columns)
#if($column.htmlType == "checkbox")
    subForm.value.$column.javaField = (subForm.value.${column.javaField} as any).split(",")
#end
#end
    subOpen.value = true
    subTitle.value = "修改${subTable.functionName}"
  })
}

/** 子表提交按钮（弹窗即时提交） */
function submitSub(): void {
  proxy.#[[$]]#refs["subFormRef"].validate((valid: boolean) => {
    if (valid) {
#foreach ($column in $subTable.columns)
#if($column.htmlType == "checkbox")
      subForm.value.$column.javaField = (subForm.value.${column.javaField} as any).join(",")
#end
#end
      subForm.value.${subTableFkclassName} = ${pkColumn.javaField} as any
      if (subForm.value.${subTable.pkColumn.javaField} != null) {
        updateSub${subClassName}(subForm.value as ${subClassName}).then(() => {
          proxy.#[[$modal]]#.msgSuccess("修改成功")
          subOpen.value = false
          getSubList()
        })
      } else {
        addSub${subClassName}(subForm.value as ${subClassName}).then(() => {
          proxy.#[[$modal]]#.msgSuccess("新增成功")
          subOpen.value = false
          getSubList()
        })
      }
    }
  })
}

/** 子表删除按钮操作 */
function handleDeleteSub(row?: ${subClassName}): void {
  const _ids = row?.${subTable.pkColumn.javaField} || subIds.value
  proxy.#[[$modal]]#.confirm('是否确认删除${subTable.functionName}编号为"' + _ids + '"的数据项？').then(function() {
    return delSub${subClassName}(_ids as number | number[])
  }).then(() => {
    getSubList()
    proxy.#[[$modal]]#.msgSuccess("删除成功")
  }).catch(() => {})
}

/** 返回按钮操作 */
function goBack(): void {
  router.back()
}

getMaster()
getSubList()
</script>
